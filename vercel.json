{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/share/review-z20-expert22", "destination": "/api/og/review-z20-expert22" },
    {
      "source": "/ia-medica/artigo/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|[Cc]rawl|[Ss]pider|[Pp]review|[Ee]mbed|[Ww]hats[Aa]pp|[Ff]acebookexternalhit|[Tt]elegram|[Ll]inked[Ii]n|[Ss]lack|[Dd]iscord|[Ss]kype|[Aa]pple|[Yy]andex|[Bb]aidu|short\\.io|[Ii]framely|[Mm]eta-[Ee]xternal|[Mm]ozilla.*compatible.*).*"
        }
      ],
      "destination": "/api/og/artigo?id=:id"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
